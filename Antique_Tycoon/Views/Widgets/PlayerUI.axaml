<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:c="using:Antique_Tycoon.Views.Controls"
             xmlns:controlViewModels="clr-namespace:Antique_Tycoon.ViewModels.ControlViewModels"
             xmlns:cv="clr-namespace:Antique_Tycoon.Converters"
             xmlns:i="clr-namespace:Antique_Tycoon.Behaviors"
             xmlns:utilities="clr-namespace:Antique_Tycoon.Utilities"
             xmlns:entities="clr-namespace:Antique_Tycoon.Models.Entities"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="Antique_Tycoon.Views.Widgets.PlayerUI"
             x:DataType="controlViewModels:PlayerUiViewModel"
             x:Name="Me">
  <UserControl.Styles>
    <Style Selector="Grid.Invisible">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
  </UserControl.Styles>
  <Design.DataContext>
    <controlViewModels:PlayerUiViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="4*,*"
        Classes.Invisible="{Binding IsVisible}">
    <Grid.Transitions>
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
      </Transitions>
    </Grid.Transitions>
    <Grid Grid.Row="0" ColumnDefinitions="*,*,*">
      <TextBlock Grid.Column="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                 FontSize="32" FontWeight="Black"
                 Margin="0 32 0 0"
                 Text="{Binding ReminderText}"
                 Tag="{Binding IsShowReminderText,Mode=OneWay}">
        <TextBlock.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" />
          </Transitions>
        </TextBlock.Transitions>
        <TextBlock.Styles>
          <Style Selector="TextBlock[Tag=True]">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(100px)" />
          </Style>
          <Style Selector="TextBlock[Tag=False]">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(-20px)" />
          </Style>
        </TextBlock.Styles>
      </TextBlock>

      <c:McContentControl Grid.Column="2">
        <ItemsControl Height="200"
                      ItemsSource="{Binding HistoryLogs}">
          <ItemsControl.Template>
            <ControlTemplate>
              <ScrollViewer>
                <Interaction.Behaviors>
                  <i:ScrollViewerAutoScrollBehavior />
                </Interaction.Behaviors>
                <ItemsPresenter />
              </ScrollViewer>
            </ControlTemplate>
          </ItemsControl.Template>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock utilities:RichTextHelper.LogSegments="{Binding LogSegments}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,4" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </c:McContentControl>
    </Grid>

    <Grid Row="1" RowDefinitions="Auto,*" Background="#A3703A">
      <StackPanel Grid.Row="0">
        <Rectangle Height="2" Fill="#694826" />
        <Rectangle Height="5" Fill="#C58747" />
      </StackPanel>

      <Grid Row="1" Margin="16"
            ColumnDefinitions="*,5*,*" ColumnSpacing="32">
        <c:PlayerCard Grid.Column="0"
                      Player="{Binding LocalPlayer}" />

        <Grid Grid.Column="1"
              ColumnDefinitions="*,*,*"
              HorizontalAlignment="Stretch" ColumnSpacing="16">

          <Panel>
            <Rectangle VerticalAlignment="Stretch" Height="2" Fill="#373737" />
          </Panel>
          <Border Grid.Column="0" Background="#6D4B27" VerticalAlignment="Stretch"
                  BorderBrush="#C58747" BorderThickness="2">
            <Panel>
              <ItemsControl ItemsSource="{Binding LocalPlayer.Estates}" />
              <TextBlock Text="地产" IsVisible="{Binding !LocalPlayer.Estates.Count}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Panel>
          </Border>

          <Border Grid.Column="1" Background="#6D4B27" VerticalAlignment="Stretch"
                  BorderBrush="#C58747" BorderThickness="2">
            <Panel>
              <ItemsControl HorizontalAlignment="Left"
                            ItemsSource="{Binding LocalPlayer.AntiqueStacks}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <!--todo 正好可以放6个 后面看看怎么改吧 -->
                    <UniformGrid Rows="2" Columns="6" ColumnSpacing="2" RowSpacing="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <!-- 这简直是审美灾难 -->
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <DataTemplate.DataType>
                      <x:Type TypeName="entities:ItemStack" x:TypeArguments="entities:Antique" />
                    </DataTemplate.DataType>
                    <Border Background="{Binding Item.Dice,Converter={x:Static cv:RarityColorConverter.DiceToBrush}}"
                            BorderBrush="#e67e22" BorderThickness="2"
                            BoxShadow="inset 0 0 12 2 #40000000">
                      <ToolTip.Tip>
                        <MultiBinding StringFormat="{}{0}&#x0a;点数：{1}&#x0a;价格：{2}">
                          <Binding Path="Item.Name"/>
                          <Binding Path="Item.Dice"/>
                          <Binding Path="Item.Value"/>
                        </MultiBinding>
                      </ToolTip.Tip>
                      <Panel>
                        <Image Margin="4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Source="{Binding Item.Image}" />
                        <TextBlock Text="{Binding Amount}"
                                   FontSize="24"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom">
                          <TextBlock.RenderTransform>
                            <TranslateTransform Y="2" X="-2" />
                          </TextBlock.RenderTransform>
                          <TextBlock.Effect>
                            <DropShadowEffect Color="#404040" BlurRadius="0" OffsetX="2.5"
                                              OffsetY="2" />
                          </TextBlock.Effect>
                        </TextBlock>
                      </Panel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="古玩" IsVisible="{Binding !LocalPlayer.AntiqueStacks.Count}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Panel>
          </Border>

          <Border Grid.Column="2" Background="#6D4B27" VerticalAlignment="Stretch"
                  BorderBrush="#C58747" BorderThickness="2">
            <Panel>
              <ItemsControl ItemsSource="{Binding LocalPlayer.Staffs}" />
              <TextBlock Text="伙计" IsVisible="{Binding !LocalPlayer.Staffs.Count}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Panel>
          </Border>

        </Grid>

        <c:McButton Grid.Column="2"
                    Classes="Confirm"
                    Padding="0"
                    Command="{Binding RollDiceCommand}"
                    HorizontalAlignment="Center" VerticalAlignment="Stretch"
                    IsEnabled="{Binding RollButtonEnable}">
          <Image Source="../../Assets/Image/GameUI/Dice.png" />
        </c:McButton>
      </Grid>
    </Grid>


    <Border x:Name="Mask"
            Grid.Row="0" Grid.RowSpan="2"
            Background="#80000000"
            IsVisible="{Binding DialogViewModel,Converter={x:Static ObjectConverters.IsNotNull}}">
      <Border
        HorizontalAlignment="{Binding DialogViewModel.HorizontalAlignment}"
        VerticalAlignment="{Binding DialogViewModel.VerticalAlignment}">
        <Border.MaxWidth>
          <MultiBinding Converter="{x:Static cv:MultiplyValuesConverter.Multiply}">
            <Binding Path="DialogViewModel.MaxWidthPercent" />
            <Binding Path="Bounds.Width" RelativeSource="{RelativeSource AncestorType=Border}" />
          </MultiBinding>
        </Border.MaxWidth>
        <Border.MaxHeight>
          <MultiBinding Converter="{x:Static cv:MultiplyValuesConverter.Multiply}">
            <Binding Path="DialogViewModel.MaxHeightPercent" />
            <Binding Path="Bounds.Height" RelativeSource="{RelativeSource AncestorType=Border}" />
          </MultiBinding>
        </Border.MaxHeight>
        <ContentControl Content="{Binding DialogViewModel}"
                        Background="Transparent">
        </ContentControl>
      </Border>
    </Border>


  </Grid>
</UserControl>