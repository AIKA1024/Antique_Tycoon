<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:c="using:Antique_Tycoon.Views.Controls"
             xmlns:controlViewModels="clr-namespace:Antique_Tycoon.ViewModels.ControlViewModels"
             xmlns:cv="clr-namespace:Antique_Tycoon.Converters"
             xmlns:i="clr-namespace:Antique_Tycoon.Behaviors"
             xmlns:utilities="clr-namespace:Antique_Tycoon.Utilities"
             xmlns:entities="clr-namespace:Antique_Tycoon.Models.Entities"
             xmlns:models="clr-namespace:Antique_Tycoon.Models"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="Antique_Tycoon.Views.Widgets.PlayerUI"
             x:DataType="controlViewModels:PlayerUiViewModel"
             x:Name="Me">
  <Design.DataContext>
    <controlViewModels:PlayerUiViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="ItemsControl.AntiqueListView">
      <Setter Property="ItemsPanel">
        <ItemsPanelTemplate>
          <WrapPanel ItemSpacing="2" LineSpacing="2" />
        </ItemsPanelTemplate>
      </Setter>
      <Setter Property="ItemTemplate">
        <DataTemplate>
          <DataTemplate.DataType>
            <x:Type TypeName="entities:ItemStack" x:TypeArguments="entities:Antique" />
          </DataTemplate.DataType>
          <Border
            Background="{Binding Item.Dice,Converter={x:Static cv:RarityColorConverter.DiceToBrush}}"
            BorderBrush="#e67e22" BorderThickness="2"
            BoxShadow="inset 0 0 12 2 #40000000">
            <ToolTip.Tip>
              <MultiBinding StringFormat="{}{0}&#x0a;点数：{1}&#x0a;价格：{2}">
                <Binding Path="Item.Name" />
                <Binding Path="Item.Dice" />
                <Binding Path="Item.Value" />
              </MultiBinding>
            </ToolTip.Tip>
            <Panel>
              <Image Margin="4"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Stretch="Uniform"
                     Source="{Binding Item.Image}" />
              <TextBlock Text="{Binding Amount}"
                         FontSize="24"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock.RenderTransform>
                  <TranslateTransform Y="2" X="-2" />
                </TextBlock.RenderTransform>
                <TextBlock.Effect>
                  <DropShadowEffect Color="#404040" BlurRadius="0" OffsetX="2.5"
                                    OffsetY="2" />
                </TextBlock.Effect>
              </TextBlock>
            </Panel>
          </Border>
        </DataTemplate>
      </Setter>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,*">
    <Grid Grid.Row="0" RowSpan="2"
          ColumnDefinitions="*,*,*">
      <TextBlock Grid.Column="1" HorizontalAlignment="Center" IsHitTestVisible="False"
                 FontSize="32" FontWeight="Black"
                 Margin="0 32 0 0"
                 Text="{Binding ReminderText}"
                 Tag="{Binding IsShowReminderText,Mode=OneWay}">
        <TextBlock.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" />
          </Transitions>
        </TextBlock.Transitions>
        <TextBlock.Styles>
          <Style Selector="TextBlock[Tag=True]">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(100px)" />
          </Style>
          <Style Selector="TextBlock[Tag=False]">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(-20px)" />
          </Style>
        </TextBlock.Styles>
      </TextBlock>

      <!-- 游戏日志 -->
      <c:McContentControl
        Grid.Row="0" Grid.Column="2">
        <ItemsControl Height="200"
                      ItemsSource="{Binding HistoryLogs}">
          <ItemsControl.Template>
            <ControlTemplate>
              <ScrollViewer>
                <Interaction.Behaviors>
                  <i:ScrollViewerAutoScrollBehavior />
                </Interaction.Behaviors>
                <ItemsPresenter />
              </ScrollViewer>
            </ControlTemplate>
          </ItemsControl.Template>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock utilities:RichTextHelper.LogSegments="{Binding LogSegments}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,4" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </c:McContentControl>
    </Grid>


    <Grid Row="1"
          RowDefinitions="1.5*,*"
          ColumnDefinitions="*,3*,*">
      <!-- 其他玩家UI -->
      <ItemsControl
        ItemsSource="{Binding OtherPlayers}"
        HorizontalAlignment="Left" VerticalAlignment="Center">
        <ItemsControl.DataTemplates>
          <DataTemplate x:DataType="models:Player">
            <Border CornerRadius="32" Background="#A3703A"
                    BorderBrush="#694826" BorderThickness="2"
                    ClipToBounds="True"
                    Padding="0 0 32 0"
                    ToolTip.Tip="查看玩家资产">
              <Grid ColumnDefinitions="*,3.5*" ColumnSpacing="32">
                <Border CornerRadius="32" Cursor="Hand" ClipToBounds="True"
                        ToolTip.Tip="定位玩家">
                  <Image Source="{Binding Avatar}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="4">
                  <TextBlock Text="{Binding Name}" />
                  <ItemsControl Classes="AntiqueListView"
                                ItemsSource="{Binding AntiqueStacks}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.DataTemplates>
      </ItemsControl>


      <!-- 本地玩家ui -->
      <Border
        Grid.Row="1" Grid.Column="0" 
        Background="#A3703A"
              Padding="16"
              HorizontalAlignment="Stretch"
              BorderBrush="#694826" BorderThickness="2"
              CornerRadius="0 8 0 0">
        <Grid ColumnDefinitions="Auto,*">
          <StackPanel Spacing="8" utilities:HoverEffect.BrightnessFactor="-0.3"
                      Cursor="Hand">
            <Image Source="{Binding LocalPlayer.Avatar}" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding LocalPlayer.Name}" HorizontalAlignment="Center" />
          </StackPanel>
          <Grid Grid.Column="1" RowDefinitions="*,*,*" Margin="32 0 0 0"
                utilities:HoverEffect.BrightnessFactor="-0.3">
            <TextBlock Grid.Row="0" Text="{Binding LocalPlayer.Money,StringFormat=💰 {0}}" />
            <ItemsControl Grid.Row="1"
                          Classes="AntiqueListView"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding LocalPlayer.AntiqueStacks}">
            </ItemsControl>
            <ItemsControl Grid.Row="2" ItemsSource="{Binding LocalPlayer.Staffs}" />
          </Grid>
        </Grid>
      </Border>

      <!-- 骰子 -->
      <c:McButton Grid.Row="1" Grid.Column="2"
                  Classes="Confirm"
                  Padding="0"
                  Command="{Binding RollDiceCommand}"
                  HorizontalAlignment="Right" VerticalAlignment="Stretch"
                  IsEnabled="{Binding RollButtonEnable}">
        <Image Source="../../Assets/Image/GameUI/Dice.png" />
      </c:McButton>
    </Grid>


    <Border x:Name="Mask"
            Grid.Row="0" Grid.RowSpan="2"
            Background="#80000000"
            Classes.Invisible="{Binding MaskInvisible}">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
        </Transitions>
      </Border.Transitions>
      <Border.Styles>
        <Style Selector="Border#Mask.Invisible">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
      </Border.Styles>
      <Border
        HorizontalAlignment="{Binding DialogViewModel.HorizontalAlignment}"
        VerticalAlignment="{Binding DialogViewModel.VerticalAlignment}">
        <Border.MaxWidth>
          <MultiBinding Converter="{x:Static cv:MultiplyValuesConverter.Multiply}">
            <Binding Path="DialogViewModel.MaxWidthPercent" />
            <Binding Path="Bounds.Width" RelativeSource="{RelativeSource AncestorType=Border}" />
          </MultiBinding>
        </Border.MaxWidth>
        <Border.MaxHeight>
          <MultiBinding Converter="{x:Static cv:MultiplyValuesConverter.Multiply}">
            <Binding Path="DialogViewModel.MaxHeightPercent" />
            <Binding Path="Bounds.Height" RelativeSource="{RelativeSource AncestorType=Border}" />
          </MultiBinding>
        </Border.MaxHeight>
        <ContentControl Content="{Binding DialogViewModel}"
                        Background="Transparent">
        </ContentControl>
      </Border>
    </Border>


  </Grid>
</UserControl>