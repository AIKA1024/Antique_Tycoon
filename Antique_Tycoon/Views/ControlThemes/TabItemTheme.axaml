<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ControlTheme x:Key="McTabItem" TargetType="TabItem">
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="Padding" Value="48 12" />
    <Setter Property="Background" Value="#D0D1D4" />
    <Setter Property="BorderBrush" Value="#E3E3E5" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid RowDefinitions="Auto,Auto">
          <Panel x:Name="TopPlaceholder" Grid.Row="0" />

          <Border Grid.Row="1"
                  BorderBrush="#1E1E1F" BorderThickness="2">
            <Grid RowDefinitions="Auto, Auto,Auto">
              <Panel Grid.Row="1">
                <Border x:Name="Border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="2">
                  <ContentPresenter Content="{TemplateBinding Header}" />
                </Border>
                
                <Grid ColumnDefinitions="*,*,*"
                      VerticalAlignment="Bottom">
                  <Rectangle x:Name="ContentButtonLine"
                    Grid.Column="1" Fill="White"/>
                </Grid>
                
              </Panel>
              

              <Rectangle x:Name="Rectangle"
                         Grid.Row="2" 
                         Fill="#58585A"/>
            </Grid>
          </Border>
        </Grid>

      </ControlTemplate>
    </Setter>

    <!-- default value -->
    <Style Selector="^TabItem">
      <Style Selector="^ /template/ Panel#TopPlaceholder">
        <Setter Property="Height" Value="0" />
      </Style>
      
      <Style Selector="^ /template/ Rectangle#ContentButtonLine">
        <Setter Property="Height" Value="0" />
      </Style>


      <Style Selector="^ /template/ Rectangle#Rectangle">
        <Setter Property="Height" Value="4" />
      </Style>
    </Style>

    <Style Selector="^TabItem:selected">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#3C8527" />
      <Setter Property="BorderBrush" Value="#4F913D" />

      <Style Selector="^ /template/ Panel#TopPlaceholder">
        <Setter Property="Height" Value="4" />
      </Style>
      
      <Style Selector="^ /template/ Rectangle#ContentButtonLine">
        <Setter Property="Height" Value="2" />
      </Style>

      <Style Selector="^ /template/ Rectangle#Rectangle">
        <Setter Property="Height" Value="0" />
      </Style>
    </Style>
  </ControlTheme>
</ResourceDictionary>